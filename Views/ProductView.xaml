<UserControl x:Class="WpfAppMobileShop.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:WpfAppMobileShop.Helpers"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"/>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" Style="{StaticResource TitleTextStyle}"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,12">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource SearchBoxStyle}" Width="300"/>
            <Button Content="THÊM" Command="{Binding AddCommand}" 
                    Style="{StaticResource SuccessButton}" Margin="12,0,0,0"/>
        </StackPanel>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Products}" 
                  SelectedItem="{Binding SelectedProduct}" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" RowHeight="40"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã" Binding="{Binding ProductId}" Width="60"/>
                <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Thương hiệu" Binding="{Binding Brand}" Width="120"/>
                <DataGridTextColumn Header="Mẫu" Binding="{Binding Model}" Width="100"/>
                <DataGridTextColumn Header="Danh mục" Binding="{Binding Category.CategoryName}" Width="130"/>
                <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat=N0}" Width="120"/>
                <DataGridTextColumn Header="Tồn kho" Binding="{Binding StockQuantity}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <md:Card Grid.Row="3" Margin="0,12,0,0" Padding="16" UniformCornerRadius="8"
                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Tên:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingProduct.ProductName}" 
                             Style="{StaticResource SearchBoxStyle}"/>
                    <TextBlock Grid.Column="2"/>
                    <TextBlock Grid.Column="3" Text="Thương hiệu:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="4" Text="{Binding EditingProduct.Brand}" 
                             Style="{StaticResource SearchBoxStyle}"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Mẫu:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingProduct.Model}" 
                             Style="{StaticResource SearchBoxStyle}"/>
                    <TextBlock Grid.Column="2"/>
                    <TextBlock Grid.Column="3" Text="Danh mục:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="4" ItemsSource="{Binding Categories}" 
                              SelectedValue="{Binding EditingProduct.CategoryId}"
                              SelectedValuePath="CategoryId" DisplayMemberPath="CategoryName" 
                              Style="{StaticResource ComboBoxFilledStyle}"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Giá:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingProduct.Price}" 
                             Style="{StaticResource SearchBoxStyle}"/>
                    <TextBlock Grid.Column="2"/>
                    <TextBlock Grid.Column="3" Text="Tồn kho:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="4" Text="{Binding EditingProduct.StockQuantity}" 
                             Style="{StaticResource SearchBoxStyle}"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Mô tả:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingProduct.Description}" 
                             Style="{StaticResource SearchBoxStyle}"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="LƯU" Command="{Binding SaveCommand}" 
                            Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
                    <Button Content="HỦY" Command="{Binding CancelCommand}" 
                            Style="{StaticResource DangerButton}"/>
                </StackPanel>
            </StackPanel>
        </md:Card>
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12"
                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="XÓA" Command="{Binding DeleteCommand}" 
                        Style="{StaticResource DangerButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>