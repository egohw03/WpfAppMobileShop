<UserControl x:Class="WpfAppMobileShop.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:WpfAppMobileShop.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="#1976D2"/>
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Height="35" ToolTip="Tìm kiếm sản phẩm..." Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              MouseDoubleClick="Product_MouseDoubleClick"
                              AlternatingRowBackground="#F5F5F5" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên SP" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Tồn" Binding="{Binding StockQuantity}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            <Border Grid.Column="2" Background="White" CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Giỏ hàng" FontSize="18" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="200" Height="30" ToolTip="Nhập SĐT khách hàng..."/>
                        <TextBlock Text="{Binding SelectedCustomer.FullName, StringFormat='KH: {0}'}" 
                                   VerticalAlignment="Center" Margin="10,0,0,0" FontSize="14"/>
                    </StackPanel>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding Cart}"
                              SelectedItem="{Binding SelectedCartItem}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#F5F5F5" RowHeight="30">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SP" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="40"/>
                            <DataGridTextColumn Header="Giá" Binding="{Binding UnitPrice, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="T.Tiền" Binding="{Binding LineTotal, StringFormat=N0}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5">
                        <Button Content="-" Command="{Binding DecreaseQuantityCommand}" 
                                Width="30" Height="30" BorderThickness="0"/>
                        <Button Content="+" Command="{Binding IncreaseQuantityCommand}" 
                                Width="30" Height="30" Margin="5,0" BorderThickness="0"/>
                        <Button Content="Xóa" Command="{Binding RemoveFromCartCommand}" 
                                Background="#F44336" Foreground="White" Height="30" Padding="10,0" BorderThickness="0"/>
                    </StackPanel>
                    <Border Grid.Row="4" Background="#E8F5E9" Padding="10" CornerRadius="5" Margin="0,5">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tổng tiền:" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat=N0}" 
                                           FontSize="20" FontWeight="Bold" Foreground="#F44336"/>
                            </Grid>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Khách đưa:" FontSize="14" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="120" Height="30" TextAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tiền thừa:" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ChangeAmount, StringFormat=N0}" 
                                           FontSize="16" FontWeight="Bold" Foreground="#4CAF50"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Button Grid.Row="5" Content="Thanh toán" Command="{Binding CheckoutCommand}"
                            Background="#4CAF50" Foreground="White" Height="45" FontSize="16" 
                            FontWeight="Bold" Margin="0,10,0,0" BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
