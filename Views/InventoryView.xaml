<UserControl x:Class="WpfAppMobileShop.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:WpfAppMobileShop.Helpers"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:LowStockToVisibilityConverter x:Key="LowStockVis"/>
        <helpers:AdjustTypeToVisibilityConverter x:Key="ImportVis"/>
        <helpers:StockStatusConverter x:Key="StockStatusConv"/>
        <helpers:StockStatusColorConverter x:Key="StockColorConv"/>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" Style="{StaticResource TitleTextStyle}"/>

        <md:Card Grid.Row="1" Padding="16" UniformCornerRadius="8" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border CornerRadius="4" BorderBrush="#DDD" BorderThickness="1" Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <md:PackIcon Kind="Magnify" FontSize="16" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}" BorderThickness="0" ToolTip="Tìm sản phẩm..."/>
                        </Grid>
                    </Border>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding CategoryFilterOptions}" SelectedItem="{Binding FilterCategory}"
                              Margin="8,0,0,0" Width="160" Style="{StaticResource ComboBoxFilledStyle}"/>
                    <Border Grid.Column="2" Background="{StaticResource DangerBrush}" CornerRadius="4" Padding="8,4" Margin="12,0,0,0"
                            Visibility="{Binding LowStockCount, Converter={StaticResource LowStockVis}}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="AlertCircle" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LowStockCount, StringFormat=' {} {0} SP sắp hết'}" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                        <Button Content="NHẬP HÀNG" Command="{Binding ImportCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/>
                        <Button Content="XUẤT HÀNG" Command="{Binding ExportCommand}"
                                Style="{StaticResource DangerButton}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False" IsReadOnly="True" Margin="0,12,0,0"
                          AlternatingRowBackground="#F5F5F5" RowHeight="36"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Danh mục" Binding="{Binding Category.CategoryName}" Width="120"/>
                        <DataGridTextColumn Header="Tồn kho" Binding="{Binding StockQuantity}" Width="100"/>
                        <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat=N0}" Width="120"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource StockStatusConv}">
                                                <Binding Path="StockQuantity"/>
                                                <Binding Path="DataContext.LowStockThreshold" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                        <TextBlock.Foreground>
                                            <MultiBinding Converter="{StaticResource StockColorConv}">
                                                <Binding Path="StockQuantity"/>
                                                <Binding Path="DataContext.LowStockThreshold" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </md:Card>

        <md:Card Grid.Row="2" Padding="16" UniformCornerRadius="8" Margin="0,12,0,0"
                 Visibility="{Binding IsAdjusting, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding AdjustType}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding AdjustQuantity}" Width="100"
                             Style="{StaticResource SearchBoxStyle}"/>
                    <ComboBox Grid.Column="3" Grid.ColumnSpan="3" SelectedItem="{Binding SelectedSupplier}"
                              DisplayMemberPath="SupplierName" Width="180"
                              ItemsSource="{Binding Suppliers}"
                              Style="{StaticResource ComboBoxFilledStyle}"
                              Visibility="{Binding AdjustType, Converter={StaticResource ImportVis}}"/>
                    <TextBlock Grid.Column="6" Text="Ghi chú:" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBox Grid.Column="7" Text="{Binding AdjustNotes}" Margin="4,0"
                             Style="{StaticResource SearchBoxStyle}"/>
                    <StackPanel Grid.Column="8" Orientation="Horizontal">
                        <Button Content="LƯU" Command="{Binding SaveAdjustCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                        <Button Content="HỦY" Command="{Binding CancelAdjustCommand}"
                                Style="{StaticResource DangerButton}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
                <TextBlock FontSize="11" Foreground="#888" Text="{Binding SelectedSupplier.SupplierName, StringFormat='NCC: {0}'}"
                           Visibility="{Binding SelectedSupplier, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </md:Card>

        <md:Card Grid.Row="3" Padding="16" UniformCornerRadius="8" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Lịch sử giao dịch" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" SelectedValue="{Binding FilterType}" SelectedValuePath="Content" Margin="20,0,0,0"
                              Width="140" Style="{StaticResource ComboBoxFilledStyle}">
                        <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                        <ComboBoxItem Content="Import"/>
                        <ComboBoxItem Content="Export"/>
                    </ComboBox>
                </Grid>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Transactions}"
                          AutoGenerateColumns="False" IsReadOnly="True" Margin="0,10,0,0"
                          RowHeight="30" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat=dd/MM/yyyy HH:mm}" Width="130"/>
                        <DataGridTextColumn Header="Sản phẩm" Binding="{Binding Product.ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Loại" Binding="{Binding Type}" Width="80"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="60"/>
                        <DataGridTextColumn Header="NV" Binding="{Binding User.FullName}" Width="120"/>
                        <DataGridTextColumn Header="Ghi chú" Binding="{Binding Notes}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </md:Card>
    </Grid>
</UserControl>
