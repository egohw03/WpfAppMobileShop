<UserControl x:Class="WpfAppMobileShop.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
              mc:Ignorable="d"
              xmlns:helpers="clr-namespace:WpfAppMobileShop.Helpers"
              d:DesignHeight="500" d:DesignWidth="900">
    <Grid Margin="16">
        <Grid.Resources>
            <helpers:BoolToVisibilityConverter x:Key="MoneyVis"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Bán hàng" Style="{StaticResource TitleTextStyle}" Margin="0,0,0,4"/>
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <md:Card Grid.Column="0" Padding="16" UniformCornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border CornerRadius="4" BorderBrush="#DDD" BorderThickness="1" Padding="0" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <md:PackIcon Kind="Magnify" FontSize="16" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}" BorderThickness="0" ToolTip="Tìm kiếm sản phẩm..."/>
                        </Grid>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              MouseDoubleClick="Product_MouseDoubleClick"
                              RowHeight="42" AlternatingRowBackground="#F5F5F5"
                              BorderThickness="0">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat=N0}" Width="120"/>
                            <DataGridTextColumn Header="Kho" Binding="{Binding StockQuantity}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </md:Card>

            <md:Card Grid.Column="2" Padding="16" UniformCornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Giỏ hàng" FontSize="18" FontWeight="SemiBold" 
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="180" CornerRadius="4" BorderBrush="#DDD" BorderThickness="1" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <md:PackIcon Kind="PhoneOutline" FontSize="16" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}" BorderThickness="0" ToolTip="Nhập SĐT khách hàng..."/>
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding SelectedCustomer.FullName, StringFormat='KH: {0}'}" 
                                   VerticalAlignment="Center" Margin="12,0,0,0" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Cart}"
                              SelectedItem="{Binding SelectedCartItem}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              RowHeight="34" AlternatingRowBackground="#F5F5F5"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="40"/>
                            <DataGridTextColumn Header="Giá" Binding="{Binding UnitPrice, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="Thành tiền" Binding="{Binding LineTotal, StringFormat=N0}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="−" Command="{Binding DecreaseQuantityCommand}" 
                                Width="32" Height="32" Style="{StaticResource MaterialDesignFlatButton}"
                                BorderThickness="1" BorderBrush="#DDD"/>
                        <Button Content="+" Command="{Binding IncreaseQuantityCommand}" 
                                Width="32" Height="32" Margin="6,0" Style="{StaticResource MaterialDesignFlatButton}"
                                BorderThickness="1" BorderBrush="#DDD"/>
                        <Button Content="XÓA" Command="{Binding RemoveFromCartCommand}" 
                                Height="32" Padding="14,0"
                                Style="{StaticResource DangerButton}"/>
                    </StackPanel>

                    <md:Card Grid.Row="4" Background="#F5F9FF" Padding="14" UniformCornerRadius="8" Margin="0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tổng tiền:" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat=N0}" 
                                           FontSize="18" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                            </Grid>
                            <Grid Margin="0,2,0,2" Visibility="{Binding DiscountAmount, Converter={StaticResource MoneyVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Giảm giá:" FontSize="12" Foreground="{StaticResource WarningBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding DiscountAmount, StringFormat=-N0}" 
                                           FontSize="14" Foreground="{StaticResource WarningBrush}"/>
                            </Grid>
                            <Grid Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding VatPercent, StringFormat='VAT ({0}%):'}" FontSize="12" Foreground="#666"/>
                                <TextBlock Grid.Column="1" Text="{Binding VatAmount, StringFormat=N0}" 
                                           FontSize="14" Foreground="#666"/>
                            </Grid>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Phải thanh toán:" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding FinalAmount, StringFormat=N0}" 
                                           FontSize="22" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Khách đưa:" FontSize="13" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="130" TextAlignment="Right"
                                         Style="{StaticResource SearchBoxStyle}"/>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tiền thừa:" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ChangeAmount, StringFormat=N0}" 
                                           FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                            </Grid>
                        </StackPanel>
                    </md:Card>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Width="130" CornerRadius="4" BorderBrush="#DDD" BorderThickness="1" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <md:PackIcon Kind="PercentOutline" FontSize="14" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding PromoCodeInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}" BorderThickness="0" ToolTip="Mã giảm giá"/>
                            </Grid>
                        </Border>
                        <Button Content="ÁP DỤNG" Command="{Binding ApplyPromoCommand}"
                                Height="34" Padding="10,0" Margin="4,0,0,0"
                                Style="{StaticResource PrimaryButton}"/>
                        <Button Content="X" Command="{Binding ClearPromoCommand}"
                                Width="34" Height="34" Margin="4,0,0,0"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                BorderThickness="1" BorderBrush="#DDD"/>
                    </StackPanel>
                    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="IN HÓA ĐƠN" Command="{Binding PrintReceiptCommand}"
                                Style="{StaticResource PrimaryButton}" Height="42" Padding="14,0" Margin="0,0,8,0"/>
                        <Button Content="THANH TOÁN (F2)" Command="{Binding CheckoutCommand}"
                                Style="{StaticResource SuccessButton}" Height="48" FontSize="16" 
                                FontWeight="Bold" HorizontalAlignment="Stretch" MinWidth="200"/>
                    </StackPanel>
                </Grid>
            </md:Card>
        </Grid>
    </Grid>
</UserControl>