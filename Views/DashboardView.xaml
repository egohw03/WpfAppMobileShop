<UserControl x:Class="WpfAppMobileShop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:WpfAppMobileShop.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <ScrollViewer>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Bảng điều khiển" Style="{StaticResource TitleTextStyle}" Margin="0,0,0,4"/>
            <TextBlock Text="Tổng quan hoạt động cửa hàng" FontSize="13" Foreground="#888" Margin="0,0,0,8"/>

            <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                         Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
                <Button Command="{Binding GoToSalesCommand}" ToolTip="Tạo đơn hàng mới"
                        Style="{StaticResource PrimaryButton}" Height="38" Padding="16,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="CashRegister" FontSize="18" Foreground="White" Margin="0,0,8,0"/>
                        <TextBlock Text="Tạo đơn hàng" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding GoToProductsCommand}" ToolTip="Thêm sản phẩm mới"
                        Style="{StaticResource PrimaryButton}" Height="38" Padding="16,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="PackageVariantClosed" FontSize="18" Foreground="White" Margin="0,0,8,0"/>
                        <TextBlock Text="Thêm sản phẩm" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding GoToReportsCommand}" ToolTip="Xem báo cáo"
                        Style="{StaticResource PrimaryButton}" Height="38" Padding="16,0">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="ChartBoxOutline" FontSize="18" Foreground="White" Margin="0,0,8,0"/>
                        <TextBlock Text="Xem báo cáo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <md:Card Grid.Column="0" Margin="6" Padding="20" UniformCornerRadius="8">
                    <md:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1976D2" Offset="0"/>
                            <GradientStop Color="#1565C0" Offset="1"/>
                        </LinearGradientBrush>
                    </md:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#33FFFFFF" CornerRadius="8" Width="48" Height="48">
                            <md:PackIcon Kind="Receipt" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalOrders}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Tổng đơn hàng" FontSize="12" Foreground="#B3FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </md:Card>

                <md:Card Grid.Column="1" Margin="6" Padding="20" UniformCornerRadius="8">
                    <md:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4CAF50" Offset="0"/>
                            <GradientStop Color="#388E3C" Offset="1"/>
                        </LinearGradientBrush>
                    </md:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#33FFFFFF" CornerRadius="8" Width="48" Height="48">
                            <md:PackIcon Kind="PackageVariantClosed" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalProducts}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Tồn kho" FontSize="12" Foreground="#B3FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </md:Card>

                <md:Card Grid.Column="2" Margin="6" Padding="20" UniformCornerRadius="8">
                    <md:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF9800" Offset="0"/>
                            <GradientStop Color="#F57C00" Offset="1"/>
                        </LinearGradientBrush>
                    </md:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#33FFFFFF" CornerRadius="8" Width="48" Height="48">
                            <md:PackIcon Kind="AccountGroup" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalCustomers}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Khách hàng" FontSize="12" Foreground="#B3FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </md:Card>

                <md:Card Grid.Column="3" Margin="6" Padding="20" UniformCornerRadius="8">
                    <md:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F44336" Offset="0"/>
                            <GradientStop Color="#D32F2F" Offset="1"/>
                        </LinearGradientBrush>
                    </md:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#33FFFFFF" CornerRadius="8" Width="48" Height="48">
                            <md:PackIcon Kind="CurrencyUsd" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding TodayRevenue, StringFormat=N0}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                <Border Background="#33FFFFFF" CornerRadius="4" Padding="4,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding RevenueTrend}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Doanh thu hôm nay" FontSize="12" Foreground="#B3FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </md:Card>
            </Grid>

            <Grid Grid.Row="4" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <md:Card Grid.Column="0" Margin="6" Padding="20" UniformCornerRadius="8">
                    <md:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#9C27B0" Offset="0"/>
                            <GradientStop Color="#7B1FA2" Offset="1"/>
                        </LinearGradientBrush>
                    </md:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#33FFFFFF" CornerRadius="8" Width="48" Height="48">
                            <md:PackIcon Kind="ClockOutline" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PendingOrders}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Đơn chờ" FontSize="12" Foreground="#B3FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </md:Card>
                <md:Card Grid.Column="1" Margin="6" Padding="20" UniformCornerRadius="8">
                    <md:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F44336" Offset="0"/>
                            <GradientStop Color="#D32F2F" Offset="1"/>
                        </LinearGradientBrush>
                    </md:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#33FFFFFF" CornerRadius="8" Width="48" Height="48">
                            <md:PackIcon Kind="AlertCircleOutline" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding LowStockProducts}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Sắp hết hàng" FontSize="12" Foreground="#B3FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </md:Card>
                <md:Card Grid.Column="2" Margin="6" Padding="20" UniformCornerRadius="8">
                    <md:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF9800" Offset="0"/>
                            <GradientStop Color="#F57C00" Offset="1"/>
                        </LinearGradientBrush>
                    </md:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#33FFFFFF" CornerRadius="8" Width="48" Height="48">
                            <md:PackIcon Kind="CalendarMonthOutline" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding MonthlyRevenue, StringFormat=N0}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Doanh thu tháng" FontSize="12" Foreground="#B3FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </md:Card>
                <md:Card Grid.Column="3" Margin="6" Padding="20" UniformCornerRadius="8">
                    <md:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00BCD4" Offset="0"/>
                            <GradientStop Color="#0097A7" Offset="1"/>
                        </LinearGradientBrush>
                    </md:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#33FFFFFF" CornerRadius="8" Width="48" Height="48">
                            <md:PackIcon Kind="AccountStarOutline" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TopCustomerName}" FontSize="20" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding TopCustomerTotal, StringFormat='KH tốt: {0:N0}'}" FontSize="12" Foreground="#B3FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </md:Card>
            </Grid>

            <Grid Grid.Row="5" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <md:Card Grid.Column="0" Margin="6" Padding="20" UniformCornerRadius="8" MinHeight="280">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <md:PackIcon Kind="ChartTimelineVariant" FontSize="20" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="  Doanh thu 7 ngày" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding RevenueSeries}" 
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            Hoverable="True"
                                            DisableAnimations="True">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding RevenueLabels}" FontSize="10"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Doanh thu" FontSize="10"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </md:Card>
                <md:Card Grid.Column="1" Margin="6" Padding="20" UniformCornerRadius="8" MinHeight="280">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <md:PackIcon Kind="Poll" FontSize="20" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="  Top 5 sản phẩm bán chạy" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <lvc:PieChart Grid.Row="1" Series="{Binding TopProductsSeries}" 
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                      Hoverable="True" DisableAnimations="True"/>
                    </Grid>
                </md:Card>
            </Grid>

            <md:Card Grid.Row="6" Margin="6,16,6,0" Padding="16" UniformCornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <md:PackIcon Kind="ReceiptTextOutline" FontSize="20" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="  Đơn hàng gần đây" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding RecentOrders}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              RowHeight="34" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã" Binding="{Binding OrderId}" Width="60"/>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding OrderDate, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                            <DataGridTextColumn Header="Khách hàng" Binding="{Binding Customer.FullName}" Width="*"/>
                            <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, StringFormat=N0}" Width="120"/>
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </md:Card>
        </Grid>
    </ScrollViewer>
</UserControl>