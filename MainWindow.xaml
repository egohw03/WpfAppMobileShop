<Window x:Class="WpfAppMobileShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:WpfAppMobileShop.ViewModels"
        xmlns:views="clr-namespace:WpfAppMobileShop.Views"
        xmlns:helpers="clr-namespace:WpfAppMobileShop.Helpers"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Mobile Shop Management"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:EqualityConverter x:Key="Equality"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="160"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PrimaryDarkBrush}" MinWidth="60">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Height="120" VerticalAlignment="Top">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1976D2" Offset="0"/>
                            <GradientStop Color="#1565C0" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Background="White" CornerRadius="25" Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="MS" FontSize="18" FontWeight="Bold" Foreground="#1976D2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="MobileShop" FontSize="15" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="0,8,0,0">
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                Style="{StaticResource SidebarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ViewDashboardOutline" FontSize="20" Margin="0,0,14,0"/>
                                <TextBlock Text="Bảng điều khiển" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Products"
                                Style="{StaticResource SidebarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="PackageVariantClosed" FontSize="20" Margin="0,0,14,0"/>
                                <TextBlock Text="Sản phẩm" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Categories"
                                Style="{StaticResource SidebarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="TagMultipleOutline" FontSize="20" Margin="0,0,14,0"/>
                                <TextBlock Text="Danh mục" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Customers"
                                Style="{StaticResource SidebarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AccountGroupOutline" FontSize="20" Margin="0,0,14,0"/>
                                <TextBlock Text="Khách hàng" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Sales"
                                Style="{StaticResource SidebarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CashRegister" FontSize="20" Margin="0,0,14,0"/>
                                <TextBlock Text="Bán hàng" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Users"
                                Style="{StaticResource SidebarButtonStyle}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AccountCogOutline" FontSize="20" Margin="0,0,14,0"/>
                                <TextBlock Text="Người dùng" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="14">
                    <Border Background="{StaticResource SidebarHoverBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentUserDisplay}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentUserRole}" Foreground="{StaticResource SidebarTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Button Command="{Binding LogoutCommand}" Style="{StaticResource SidebarLogoutStyle}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Logout" FontSize="18" Margin="0,0,14,0"/>
                            <TextBlock Text="Đăng xuất" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource PageBgBrush}">
            <ContentControl Content="{Binding CurrentViewModel}" Margin="12"/>
        </Border>
    </Grid>
</Window>