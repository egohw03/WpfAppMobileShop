<UserControl x:Class="WpfAppMobileShop.Views.PromoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:WpfAppMobileShop.Helpers"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" Style="{StaticResource TitleTextStyle}"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,12">
            <Border Width="300" CornerRadius="4" BorderBrush="#DDD" BorderThickness="1" Padding="0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <md:PackIcon Kind="Magnify" FontSize="16" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBoxStyle}" BorderThickness="0" ToolTip="Tìm mã giảm giá..."/>
                </Grid>
            </Border>
            <Button Content="THÊM MÃ" Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="12,0,0,0"/>
        </StackPanel>
        <DataGrid Grid.Row="2" ItemsSource="{Binding PromoCodes}" SelectedItem="{Binding SelectedPromo}" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F5F5F5" RowHeight="36" BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã" Binding="{Binding Code}" Width="150"/>
                <DataGridTextColumn Header="Loại" Binding="{Binding DiscountType}" Width="80"/>
                <DataGridTextColumn Header="Giá trị" Binding="{Binding DiscountValue, StringFormat=N0}" Width="100"/>
                <DataGridTextColumn Header="Đơn tối thiểu" Binding="{Binding MinOrderAmount, StringFormat=N0}" Width="130"/>
                <DataGridTextColumn Header="Hạn dùng" Binding="{Binding ExpiryDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                <DataGridTextColumn Header="Kích hoạt" Binding="{Binding IsActive}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <md:Card Grid.Row="3" Margin="0,12,0,0" Padding="16" UniformCornerRadius="8" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Mã:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingPromo.Code}" Style="{StaticResource SearchBoxStyle}"/>
                    <TextBlock Grid.Column="3" Text="Loại:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="4" SelectedValue="{Binding EditingPromo.DiscountType}" SelectedValuePath="Content" Style="{StaticResource ComboBoxFilledStyle}">
                        <ComboBoxItem Content="Percent"/><ComboBoxItem Content="Fixed"/>
                    </ComboBox>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Giá trị:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingPromo.DiscountValue}" Style="{StaticResource SearchBoxStyle}"/>
                    <TextBlock Grid.Column="3" Text="Đơn tối thiểu:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="4" Text="{Binding EditingPromo.MinOrderAmount}" Style="{StaticResource SearchBoxStyle}"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Hạn dùng:" VerticalAlignment="Center"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding EditingPromo.ExpiryDate}" Style="{StaticResource DatePickerFilledStyle}"/>
                    <TextBlock Grid.Column="3" Text="Kích hoạt:" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="4" IsChecked="{Binding EditingPromo.IsActive}" VerticalAlignment="Center" Margin="8,0"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="LƯU" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
                    <Button Content="HỦY" Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}"/>
                </StackPanel>
            </StackPanel>
        </md:Card>
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12" Visibility="{Binding IsEditing, Converter={StaticResource InvBoolToVis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="XÓA" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
