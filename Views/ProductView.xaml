<UserControl x:Class="WpfAppMobileShop.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:WpfAppMobileShop.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="#1976D2"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300" Height="30" ToolTip="Tìm kiếm sản phẩm..."/>
            <Button Content="+ Thêm" Command="{Binding AddCommand}" 
                    Background="#4CAF50" Foreground="White" Margin="10,0,0,0"
                    Height="30" Padding="10,0" BorderThickness="0"/>
        </StackPanel>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Products}" 
                  SelectedItem="{Binding SelectedProduct}" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" RowHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã" Binding="{Binding ProductId}" Width="60"/>
                <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Thương hiệu" Binding="{Binding Brand}" Width="120"/>
                <DataGridTextColumn Header="Mẫu" Binding="{Binding Model}" Width="100"/>
                <DataGridTextColumn Header="Danh mục" Binding="{Binding Category.CategoryName}" Width="130"/>
                <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat=N0}" Width="120"/>
                <DataGridTextColumn Header="Tồn kho" Binding="{Binding StockQuantity}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="3" Background="#E3F2FD" Padding="15" Margin="0,10,0,0"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Tên sản phẩm:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingProduct.ProductName}" Height="30"/>
                    <TextBlock Grid.Column="2"/>
                    <TextBlock Grid.Column="3" Text="Thương hiệu:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="4" Text="{Binding EditingProduct.Brand}" Height="30"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Mẫu:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingProduct.Model}" Height="30"/>
                    <TextBlock Grid.Column="2"/>
                    <TextBlock Grid.Column="3" Text="Danh mục:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="4" ItemsSource="{Binding Categories}" 
                              SelectedValue="{Binding EditingProduct.CategoryId}"
                              SelectedValuePath="CategoryId" DisplayMemberPath="CategoryName" Height="30"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Giá:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingProduct.Price}" Height="30"/>
                    <TextBlock Grid.Column="2"/>
                    <TextBlock Grid.Column="3" Text="Tồn kho:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="4" Text="{Binding EditingProduct.StockQuantity}" Height="30"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Mô tả:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EditingProduct.Description}" Height="30"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Lưu" Command="{Binding SaveCommand}" 
                            Background="#1976D2" Foreground="White" Height="35" Padding="15,0" Margin="0,0,10,0" BorderThickness="0"/>
                    <Button Content="Hủy" Command="{Binding CancelCommand}" 
                            Background="#F44336" Foreground="White" Height="35" Padding="15,0" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <Border Grid.Row="3" Margin="0,10,0,0" Padding="15"
                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Xóa" Command="{Binding DeleteCommand}" 
                        Background="#F44336" Foreground="White" Height="35" Padding="15,0" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
