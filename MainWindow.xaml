<Window x:Class="WpfAppMobileShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:WpfAppMobileShop.ViewModels"
        xmlns:views="clr-namespace:WpfAppMobileShop.Views"
        mc:Ignorable="d"
        Title="Mobile Shop Management"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ProductViewModel}">
            <views:ProductView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CategoryViewModel}">
            <views:CategoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CustomerViewModel}">
            <views:CustomerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SalesViewModel}">
            <views:SalesView/>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="143"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#1E1E2D" MinWidth="60">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="10">
                    <Border Background="#1976D2" CornerRadius="5" Padding="10">
                        <TextBlock Text="MobileShop" FontSize="16" FontWeight="Bold" 
                                   Foreground="White" TextAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button Content="  📊  Bảng điều khiển" 
                            Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                            Background="Transparent" Foreground="#A2A3B7" FontSize="14"
                            Height="45" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    Padding="5">
                                                <ContentPresenter HorizontalAlignment="Left" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#27273A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="  📦  Sản phẩm" 
                            Command="{Binding NavigateCommand}" CommandParameter="Products"
                            Background="Transparent" Foreground="#A2A3B7" FontSize="14"
                            Height="45" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    Padding="5">
                                                <ContentPresenter HorizontalAlignment="Left" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#27273A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="  🏷️  Danh mục" 
                            Command="{Binding NavigateCommand}" CommandParameter="Categories"
                            Background="Transparent" Foreground="#A2A3B7" FontSize="14"
                            Height="45" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    Padding="5">
                                                <ContentPresenter HorizontalAlignment="Left" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#27273A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="  👥  Khách hàng" 
                            Command="{Binding NavigateCommand}" CommandParameter="Customers"
                            Background="Transparent" Foreground="#A2A3B7" FontSize="14"
                            Height="45" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    Padding="5">
                                                <ContentPresenter HorizontalAlignment="Left" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#27273A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="  💰  Bán hàng" 
                            Command="{Binding NavigateCommand}" CommandParameter="Sales"
                            Background="Transparent" Foreground="#A2A3B7" FontSize="14"
                            Height="45" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    Padding="5">
                                                <ContentPresenter HorizontalAlignment="Left" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#27273A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="10">
                    <Button Content="⏻" Background="Transparent" Foreground="#A2A3B7"
                            Height="45" FontSize="16" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Column="1" Background="#F5F5F5">
            <ContentControl Content="{Binding CurrentViewModel}" Margin="10"/>
        </Border>
    </Grid>
</Window>
